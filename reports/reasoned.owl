<rdf:RDF xmlns="https://cdm.ovh/rsm/list2#"
     xml:base="https://cdm.ovh/rsm/list2"
     xmlns:cc="http://creativecommons.org/ns#"
     xmlns:dce="http://purl.org/dc/elements/1.1/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
