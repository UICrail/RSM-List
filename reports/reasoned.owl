    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- https://cdm.ovh/rsm/list2#hasContents -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/list2#hasContents">
        <rdfs:subPropertyOf rdf:resource="https://cdm.ovh/rsm/list2#hasListProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://cdm.ovh/rsm/list2#OWLList"/>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rsm/list2#hasListProperty -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/list2#hasListProperty"/>
    


    <!-- https://cdm.ovh/rsm/list2#hasNext -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/list2#hasNext">
        <rdfs:subPropertyOf rdf:resource="https://cdm.ovh/rsm/list2#isFollowedBy"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://cdm.ovh/rsm/list2#OWLList"/>
        <rdfs:range rdf:resource="https://cdm.ovh/rsm/list2#ListNode"/>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rsm/list2#isFollowedBy -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/list2#isFollowedBy">
        <rdfs:subPropertyOf rdf:resource="https://cdm.ovh/rsm/list2#hasListProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <rdfs:domain rdf:resource="https://cdm.ovh/rsm/list2#OWLList"/>
        <rdfs:range rdf:resource="https://cdm.ovh/rsm/list2#ListNode"/>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- https://cdm.ovh/rsm/list2#EmptyList -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/list2#EmptyList">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rsm/list2#ListNode"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/rsm/list2#OWLList"/>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/list2#ListNode -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/list2#ListNode"/>
    


    <!-- https://cdm.ovh/rsm/list2#OWLList -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/list2#OWLList">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rsm/list2#ListNode"/>
    </owl:Class>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Individuals
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- https://cdm.ovh/rsm/list2#emptyList -->

    <owl:NamedIndividual rdf:about="https://cdm.ovh/rsm/list2#emptyList">
        <rdf:type rdf:resource="https://cdm.ovh/rsm/list2#EmptyList"/>
    </owl:NamedIndividual>
</rdf:RDF>



