@prefix vann: <http://purl.org/vocab/vann/> .
@base <https://cdm.ovh/rsm/list2#> .

<https://cdm.ovh/rsm/list2> rdf:type owl:Ontology ;
                             owl:versionIRI <https://cdm.ovh/rsm/list2/0.1/> ;
                             cc:license <http://creativecommons.org/licenses/by/3.0/> ;
                             dce:creator "this version: Airy Magnien (amagnien@hotmail.fr)" ;
                             dce:date "12 March 2026" ;
                             dce:description "A set of entities used to describe the OWL list pattern." ;
                             dce:language "en" ;
                             dce:title "List (modified)"@en ;
                             vann:preferredNamespacePrefix "list" ;
                             vann:preferredNamespaceUri "https://cdm.ovh/rsm/list2" ;
                             rdfs:comment """This ontology is derived from the ontology developed by Pauwels & Terkaj,  originally published by Drummond et al., with namespace http://www.co-ode.org/ontologies/lists/2008/09/11/list.owl# and available at web location http://owl.cs.manchester.ac.uk/wp-content/uploads/2015/07/list.owl_.txt on 11 December 2015.

The main changes are OWL2 RL compliance and the changed handling of EmptyList, for which an individual is also provided.

The original terminology was kept."""@en ,
                                          "A set of entities used to describe the OWL list pattern. " ;
                             owl:versionInfo 0.1 ;
                             prov:wasDerivedFrom <https://w3id.org/list> .

#################################################################
#    Annotation properties
#################################################################

###  http://creativecommons.org/ns#license
cc:license rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/creator
dce:creator rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/date
dce:date rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/description
dce:description rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/language
dce:language rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/title
dce:title rdf:type owl:AnnotationProperty .


###  http://purl.org/vocab/vann/preferredNamespacePrefix
vann:preferredNamespacePrefix rdf:type owl:AnnotationProperty .


###  http://purl.org/vocab/vann/preferredNamespaceUri
vann:preferredNamespaceUri rdf:type owl:AnnotationProperty .


###  http://www.w3.org/ns/prov#wasDerivedFrom
prov:wasDerivedFrom rdf:type owl:AnnotationProperty .


#################################################################
#    Object Properties
#################################################################

###  https://cdm.ovh/rsm/list2#hasContents
:hasContents rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf :hasListProperty ;
             rdf:type owl:FunctionalProperty ;
             rdfs:domain :OWLList .


###  https://cdm.ovh/rsm/list2#hasListProperty
:hasListProperty rdf:type owl:ObjectProperty .


###  https://cdm.ovh/rsm/list2#hasNext
:hasNext rdf:type owl:ObjectProperty ;
         rdfs:subPropertyOf :isFollowedBy ;
         rdf:type owl:FunctionalProperty ;
         rdfs:domain :OWLList ;
         rdfs:range :ListNode .


###  https://cdm.ovh/rsm/list2#isFollowedBy
:isFollowedBy rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf :hasListProperty ;
              rdf:type owl:TransitiveProperty ;
              rdfs:domain :OWLList ;
              rdfs:range :ListNode .


#################################################################
#    Classes
#################################################################

###  https://cdm.ovh/rsm/list2#EmptyList
:EmptyList rdf:type owl:Class ;
           rdfs:subClassOf :ListNode ;
           owl:disjointWith :OWLList .


###  https://cdm.ovh/rsm/list2#ListNode
:ListNode rdf:type owl:Class .


###  https://cdm.ovh/rsm/list2#OWLList
:OWLList rdf:type owl:Class ;
         rdfs:subClassOf :ListNode .


#################################################################
#    Individuals
#################################################################

###  https://cdm.ovh/rsm/list2#emptyList
:emptyList rdf:type owl:NamedIndividual ,
                    :EmptyList .


