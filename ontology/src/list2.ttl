@base <https://cdm.ovh/rsm/list2> .

<https://cdm.ovh/rsm/list2> rdf:type owl:Ontology ;
                             owl:versionIRI <https://cdm.ovh/rsm/list2/0.2/list2> ;
                             dc:creator "Airy Magnien" ;
                             dc:date "26 June 2026"@en ;
                             dc:description """This ontology is derived from the ontology developed by Pauwels & Terkaj,  originally published by Drummond et al., with namespace http://www.co-ode.org/ontologies/lists/2008/09/11/list.owl# and available at web location http://owl.cs.manchester.ac.uk/wp-content/uploads/2015/07/list.owl_.txt on 11 December 2015.

The main changes are OWL2 RL compliance and the changed handling of EmptyList, for which an individual is also provided.

The original terminology was kept."""@en ;
                             dc:title "Linked list ontology"@en ;
                             dcterms:license "http://creativecommons.org/licenses/by/3.0/"@en ;
                             rdfs:label "Linked list ontology"@en ;
                             owl:versionInfo "0.2: minor changes following the update of the GRAPHOL file"@en ;
                             vann:preferredNamespacePrefix "list" ;
                             vann:preferredNamespaceURI "https://cdm.ovh/rsm/list2/list2" .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/elements/1.1/creator
dc:creator rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/date
dc:date rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/description
dc:description rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/title
dc:title rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/license
dcterms:license rdf:type owl:AnnotationProperty .


###  https://vocab.org/vann/preferredNamespacePrefix
vann:preferredNamespacePrefix rdf:type owl:AnnotationProperty .


###  https://vocab.org/vann/preferredNamespaceURI
vann:preferredNamespaceURI rdf:type owl:AnnotationProperty .


#################################################################
#    Object Properties
#################################################################

###  https://w3id.org/list#hasContents
<https://w3id.org/list#hasContents> rdf:type owl:ObjectProperty ,
                                             owl:FunctionalProperty ;
                                    rdfs:domain <https://w3id.org/list#OWLList> ;
                                    rdfs:comment "list node contents with arbitrary type"@en ;
                                    rdfs:label "has contents"@en .


###  https://w3id.org/list#hasNext
<https://w3id.org/list#hasNext> rdf:type owl:ObjectProperty ;
                                rdfs:subPropertyOf <https://w3id.org/list#isFollowedBy> ;
                                rdf:type owl:FunctionalProperty ;
                                rdfs:domain <https://w3id.org/list#OWLList> ;
                                rdfs:range list:ListNode ;
                                rdfs:comment "provides the next element in the list. A functional property with an existential restriction, expressing multiplicity = 1 in an RL-compatible way."@en ;
                                rdfs:label "has next"@en .


###  https://w3id.org/list#isFollowedBy
<https://w3id.org/list#isFollowedBy> rdf:type owl:ObjectProperty ,
                                              owl:TransitiveProperty ;
                                     rdfs:domain <https://w3id.org/list#OWLList> ;
                                     rdfs:range list:ListNode ;
                                     rdfs:comment "transitive closure of has next. Provides all downstream list elements."@en ;
                                     rdfs:label "is followed by"@en .


#################################################################
#    Classes
#################################################################

###  https://cdm.ovh/rsm/list2/list2#ListNode
list:ListNode rdf:type owl:Class ;
              rdfs:comment "superclass for the disjoint OWL list and empty list classes."@en ;
              rdfs:label "List node"@en .


###  https://w3id.org/list#EmptyList
<https://w3id.org/list#EmptyList> rdf:type owl:Class ;
                                  rdfs:subClassOf list:ListNode ;
                                  owl:disjointWith <https://w3id.org/list#OWLList> ;
                                  rdfs:comment "Instances of EmptyList explicitly finish the list. They have no successor item nor content."@en ;
                                  rdfs:label "Empty list"@en .


###  https://w3id.org/list#OWLList
<https://w3id.org/list#OWLList> rdf:type owl:Class ;
                                rdfs:subClassOf list:ListNode ;
                                rdfs:comment "OWLList is used to represent linked lists. Instances of OWLList are list elements; they have at most one direct successor (the value of property hasNext)."@en ;
                                rdfs:label "OWL list"@en .


#################################################################
#    Individuals
#################################################################

###  https://cdm.ovh/rsm/list2/list2#emptyList
list:emptyList rdf:type owl:NamedIndividual ,
                        <https://w3id.org/list#EmptyList> ;
               rdfs:label "empty list"@en .


